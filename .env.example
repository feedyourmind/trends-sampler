# Postgres connection. The tool keeps its data in its own `trends_sampler`
# schema (bootstrapped automatically on first write).
DATABASE_URL=

# Single-user login.
AUTH_USER=
AUTH_PASS=

# Random secret; the value the session cookie is set to. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_TOKEN=

# Shared secret for the cron endpoint (Vercel sends it as a bearer token).
CRON_SECRET=

# Reddit Data API credentials (script-type app). Until these are set the
# scheduled sampler is a no-op — the tool never calls Reddit without them.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# Optional override; defaults to nodejs:trends-sampler:v1.0 (by /u/Just-Grocery-2229)
# REDDIT_USER_AGENT=
